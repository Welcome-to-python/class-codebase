tasks = []

while True:
    print("\n1.Add 2.View 3.Delete 4.Exit")
    ch = input("Choice: ")

    if ch == '1':
        tasks.append(input("Task: "))
    elif ch == '2':
        for i, t in enumerate(tasks):
            print(i+1, t)
    elif ch == '3':
        tasks.pop(int(input("Task number: "))-1)
    else:
        break
